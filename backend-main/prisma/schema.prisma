  created_at                                  DateTime?           @default(now()) @db.Timestamp(6)
  updated_at                                  DateTime?           @default(now()) @db.Timestamp(6)
  created_by                                  String?             @db.VarChar(8)
  updated_by                                  String?             @db.VarChar(8)
  users_subject_plo_mapping_created_byTousers users?              @relation("subject_plo_mapping_created_byTousers", fields: [created_by], references: [user_id], onUpdate: NoAction, map: "fk_created_by")
  learning_outcomes                           learning_outcomes?  @relation(fields: [outcome_id], references: [outcome_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_outcome")
  subjects                                    subjects            @relation(fields: [subject_id], references: [subject_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subject")
  users_subject_plo_mapping_updated_byTousers users?              @relation("subject_plo_mapping_updated_byTousers", fields: [updated_by], references: [user_id], onUpdate: NoAction, map: "fk_updated_by")

  @@unique([subject_id, outcome_id], map: "unique_mapping")
}

model subject_score_ratio {
  score_ratio_id       Int                    @id @default(autoincrement())
  sequence_order       Int
  score_category       String
  weight               Int?                   @default(0) @db.SmallInt
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  section_id           Int?
  activities           activities[]
  activity_clo_mapping activity_clo_mapping[]
  course_sections      course_sections?       @relation(fields: [section_id], references: [section_id], onDelete: Cascade)
}

model subjects {
  subject_id          String                @id @db.VarChar(20)
  subject_name_en     String                @db.VarChar(200)
  subject_name_th     String                @db.VarChar(200)
  credits             Int
  description_th      String?
  description_en      String?
  created_at          DateTime?             @default(dbgenerated("(CURRENT_TIMESTAMP AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamptz(6)
  updated_at          DateTime?             @default(dbgenerated("(CURRENT_TIMESTAMP AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamptz(6)
  created_by          String?               @db.VarChar(8)
  updated_by          String?               @db.VarChar(8)
  is_active           Boolean?              @default(true)
  department_id       String?               @db.VarChar(20)
  program_subjects    program_subjects[]
  semester_courses    semester_courses[]
  subject_plo_mapping subject_plo_mapping[]
  departments         departments?          @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subjects_department")
}

model user_image {
  id         Int       @id @default(autoincrement())
  user_id    String    @unique(map: "unique_user_image") @db.VarChar(8)
  image_path String    @db.VarChar(255)
  created_at DateTime? @default(dbgenerated("(CURRENT_TIMESTAMP AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_image_user")

  @@index([user_id], map: "idx_user_image_user_id")
}

model user_log {
  id         Int       @id @default(autoincrement())
  user_id    String    @db.VarChar(8)
  activity   String    @db.VarChar(20)
  time_stamp DateTime? @default(dbgenerated("(now() AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamptz(6)
}

model user_roles {
  id                                  Int       @id @default(autoincrement())
  user_id                             String    @db.VarChar(8)
  scope_id                            String?   @db.VarChar(10)
  assigned_at                         DateTime? @default(dbgenerated("(CURRENT_TIMESTAMP AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamptz(6)
  assigned_by                         String?   @db.VarChar(8)
  is_active                           Boolean?  @default(true)
  role_id                             String?   @db.VarChar(20)
  users_user_roles_assigned_byTousers users?    @relation("user_roles_assigned_byTousers", fields: [assigned_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  roles                               roles?    @relation(fields: [role_id], references: [role_id], onDelete: Restrict)
  users_user_roles_user_idTousers     users     @relation("user_roles_user_idTousers", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, role_id, scope_id])
}

model users {
  user_id                                                   String                  @id @db.VarChar(8)
  email                                                     String                  @unique @db.VarChar(100)
  phone                                                     String?                 @db.VarChar(30)
  title_th                                                  String?                 @db.VarChar(30)
  first_name_th                                             String?                 @db.VarChar(100)
  last_name_th                                              String?                 @db.VarChar(100)
  title_en                                                  String?                 @db.VarChar(30)
  first_name_en                                             String?                 @db.VarChar(100)
  last_name_en                                              String?                 @db.VarChar(100)
  department_id                                             String?                 @db.Char(2)
  program_id                                                String?                 @db.VarChar(10)
  status                                                    status_enum?            @default(active)
  created_at                                                DateTime?               @default(dbgenerated("(CURRENT_TIMESTAMP AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamp(6)
  updated_at                                                DateTime?               @default(dbgenerated("(CURRENT_TIMESTAMP AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamp(6)
  is_verified                                               Boolean?                @default(false)
  verification_token                                        String?                 @db.VarChar(255)
  password                                                  String?                 @db.VarChar(255)
  activity_evidence_activity_evidence_updated_byTousers     activity_evidence[]     @relation("activity_evidence_updated_byTousers")
  activity_evidence_activity_evidence_uploaded_byTousers    activity_evidence[]     @relation("activity_evidence_uploaded_byTousers")
  learning_outcomes_learning_outcomes_created_byTousers     learning_outcomes[]     @relation("learning_outcomes_created_byTousers")
  learning_outcomes_learning_outcomes_updated_byTousers     learning_outcomes[]     @relation("learning_outcomes_updated_byTousers")
  portfolio                                                 portfolio[]
  portfolio_activities                                      portfolio_activities[]
  portfolio_award                                           portfolio_award[]
  portfolio_certificate                                     portfolio_certificate[]
  portfolio_education                                       portfolio_education[]
  portfolio_internship                                      portfolio_internship[]
  portfolio_personal                                        portfolio_personal?
  portfolio_skill                                           portfolio_skill[]
  portfolio_thesis                                          portfolio_thesis[]
  portfolio_training                                        portfolio_training[]
  student                                                   student?
  subject_plo_mapping_subject_plo_mapping_created_byTousers subject_plo_mapping[]   @relation("subject_plo_mapping_created_byTousers")
  subject_plo_mapping_subject_plo_mapping_updated_byTousers subject_plo_mapping[]   @relation("subject_plo_mapping_updated_byTousers")
  user_image                                                user_image?
  user_roles_user_roles_assigned_byTousers                  user_roles[]            @relation("user_roles_assigned_byTousers")
  user_roles_user_roles_user_idTousers                      user_roles[]            @relation("user_roles_user_idTousers")
}

